{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "test-lib": {
      "projectType": "library",
      "root": "projects/test-lib",
      "sourceRoot": "projects/test-lib/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/test-lib/ng-package.json"
          }
        },
        "prism": {
          "builder": "@ng-prism/core:serve",
          "options": {
            "entryPoint": "projects/test-lib/src/public-api.ts",
            "prismProject": "test-lib-prism",
            "libraryProject": "test-lib",
            "port": 4400
          }
        },
        "prism-build": {
          "builder": "@ng-prism/core:build",
          "options": {
            "entryPoint": "projects/test-lib/src/public-api.ts",
            "prismProject": "test-lib-prism",
            "libraryProject": "test-lib",
            "outputPath": "dist/test-lib-prism"
          }
        }
      }
    },
    "test-lib-prism": {
      "projectType": "application",
      "root": "projects/test-lib-prism",
      "sourceRoot": "projects/test-lib-prism/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": {
              "base": "dist/test-lib-prism",
              "browser": ""
            },
            "index": "projects/test-lib-prism/src/index.html",
            "browser": "projects/test-lib-prism/src/main.ts",
            "tsConfig": "projects/test-lib-prism/tsconfig.app.json",
            "styles": [
              "node_modules/highlight.js/styles/base16/solarized-dark.min.css"
            ],
            "polyfills": ["zone.js"],
            "allowedCommonJsDependencies": ["highlight.js"],
            "preserveSymlinks": true
          },
          "configurations": {
            "production": {
              "outputHashing": "all"
            },
            "development": {
              "outputHashing": "none",
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "test-lib-prism:build:development",
            "port": 4400,
            "hmr": true,
            "liveReload": true
          }
        }
      }
    },
    "test-ui-kit": {
      "projectType": "library",
      "root": "projects/test-ui-kit",
      "sourceRoot": "projects/test-ui-kit",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/test-ui-kit/ng-package.json"
          }
        },
        "prism": {
          "builder": "@ng-prism/core:serve",
          "options": {
            "entryPoint": "projects/test-ui-kit/public-api.ts",
            "prismProject": "test-ui-kit-prism",
            "libraryProject": "test-ui-kit",
            "port": 4401
          }
        },
        "prism-build": {
          "builder": "@ng-prism/core:build",
          "options": {
            "entryPoint": "projects/test-ui-kit/public-api.ts",
            "prismProject": "test-ui-kit-prism",
            "libraryProject": "test-ui-kit",
            "outputPath": "dist/test-ui-kit-prism"
          }
        }
      }
    },
    "test-ui-kit-prism": {
      "projectType": "application",
      "root": "projects/test-ui-kit-prism",
      "sourceRoot": "projects/test-ui-kit-prism/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": {
              "base": "dist/test-ui-kit-prism",
              "browser": ""
            },
            "index": "projects/test-ui-kit-prism/src/index.html",
            "browser": "projects/test-ui-kit-prism/src/main.ts",
            "tsConfig": "projects/test-ui-kit-prism/tsconfig.app.json",
            "styles": [
              "node_modules/highlight.js/styles/base16/solarized-dark.min.css"
            ],
            "polyfills": ["zone.js"],
            "allowedCommonJsDependencies": ["highlight.js"],
            "preserveSymlinks": true
          },
          "configurations": {
            "production": { "outputHashing": "all" },
            "development": {
              "outputHashing": "none",
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "test-ui-kit-prism:build:development",
            "port": 4401,
            "hmr": true,
            "liveReload": true
          }
        }
      }
    }
  }
}
