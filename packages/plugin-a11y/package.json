{
  "name": "@ng-prism/plugin-a11y",
  "version": "21.0.0",
  "description": "Accessibility audit panel for ng-prism, powered by axe-core.",
  "keywords": [
    "ng-prism",
    "accessibility",
    "a11y",
    "axe-core",
    "plugin",
    "angular",
    "styleguide"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "ng-prism": ">=21.0.0",
    "@angular/core": ">=20.0.0",
    "axe-core": ">=4.0.0",
    "highlight.js": ">=11.0.0",
    "ngx-highlightjs": ">=14.0.0"
  },
  "devDependencies": {
    "ng-prism": "*"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dyingangel666/ng-prism.git",
    "directory": "packages/plugin-a11y"
  },
  "homepage": "https://dyingangel666.github.io/ng-prism/",
  "bugs": "https://github.com/dyingangel666/ng-prism/issues"
