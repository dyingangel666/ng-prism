{
  "name": "@ng-prism/plugin-figma",
  "version": "21.0.0",
  "description": "Figma design embed panel for ng-prism.",
  "keywords": [
    "ng-prism",
    "figma",
    "plugin",
    "angular",
    "styleguide"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "ng-prism": ">=21.0.0",
    "@angular/core": ">=20.0.0",
    "html2canvas": ">=1.4.0",
    "pixelmatch": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "html2canvas": {
      "optional": true
    },
    "pixelmatch": {
      "optional": true
    }
  },
  "devDependencies": {
    "ng-prism": "*"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dyingangel666/ng-prism.git",
    "directory": "packages/plugin-figma"
  },
  "homepage": "https://dyingangel666.github.io/ng-prism/",
  "bugs": "https://github.com/dyingangel666/ng-prism/issues"
}
