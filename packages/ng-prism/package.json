{
  "name": "@ng-prism/core",
  "version": "21.12.0",
  "description": "ng-prism — the Angular-native Storybook alternative. Lightweight component showcase with @Showcase decorator, no story files needed.",
  "keywords": [
    "ng-prism",
    "angular",
    "angular21",
    "ng",
    "storybook",
    "storybook-alternative",
    "angular-storybook",
    "component-library",
    "component-explorer",
    "ui-catalog",
    "styleguide",
    "angular-styleguide",
    "design-system",
    "showcase",
    "showcase-decorator",
    "signal-inputs",
    "standalone-components"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js",
      "default": "./dist/plugin/index.js"
    },
    "./transformer": {
      "types": "./dist/transformer/index.d.ts",
      "import": "./dist/transformer/index.js",
      "default": "./dist/transformer/index.js"
    },
    "./schematics/utils": {
      "types": "./dist/schematics/utils/index.d.ts",
      "import": "./dist/schematics/utils/index.js",
      "default": "./dist/schematics/utils/index.js"
    }
  },
  "bin": {
    "ng-prism-strip": "./dist/transformer/cli.js"
  },
  "ng-add": {
    "save": "devDependencies"
  },
  "ng-update": {
    "migrations": "./schematics/migrations.json"
  },
  "schematics": "./schematics/collection.json",
  "builders": "./builders.json",
  "files": [
    "dist",
    "schematics",
    "builders.json",
    "src/builder/serve/schema.json",
    "src/builder/build/schema.json",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "@angular/core": ">=20.0.0",
    "@angular/common": ">=20.0.0",
    "@angular-devkit/architect": ">=0.2000.0",
    "@angular-devkit/core": ">=20.0.0",
    "@angular-devkit/schematics": ">=20.0.0",
    "typescript": ">=5.5.0",
    "highlight.js": ">=11.0.0",
    "ngx-highlightjs": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "@angular-devkit/architect": {
      "optional": false
    },
    "@angular-devkit/schematics": {
      "optional": false
    }
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "tslib": "^2.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dyingangel666/ng-prism.git",
    "directory": "packages/ng-prism"
  },
  "homepage": "https://dyingangel666.github.io/ng-prism/",
  "bugs": "https://github.com/dyingangel666/ng-prism/issues"
}
