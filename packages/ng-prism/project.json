{
  "name": "ng-prism",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node_modules/.bin/ngc --project packages/ng-prism/tsconfig.lib.json"
      },
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"]
    }
  }
}
