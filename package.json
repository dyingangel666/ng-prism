{
  "name": "ng-prism-workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "docs": "npx docsify-cli serve docs --port 3000",
    "build": "nx build ng-prism",
    "build:all": "nx build ng-prism && nx run-many -t build --projects='plugin-box-model,plugin-figma,plugin-jsdoc,plugin-perf'",
    "test": "nx test ng-prism",
    "publish": "./scripts/publish.sh",
    "test:workspace:setup": "nx build ng-prism",
    "test:workspace:setup:nocache": "nx build ng-prism --skip-nx-cache && cd test-workspace && npm install --prefer-online",
    "test:workspace:serve": "cd test-workspace && ng run test-lib:prism",
    "test:workspace:clean": "cd test-workspace && rm -rf node_modules package-lock.json ng-prism.config.ts && git checkout -- angular.json package.json"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@angular-devkit/architect": "0.2101.4",
    "@angular-devkit/core": "^21.0.0",
    "@angular-devkit/schematics": "^21.1.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@nx/jest": "22.5.2",
    "@nx/js": "22.5.2",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "~0.2.38",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "axe-core": "^4.11.1",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "ngx-highlightjs": "^14.0.1",
    "nx": "22.5.2",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "prettier": "^2.6.2",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "verdaccio": "^6.0.5"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
